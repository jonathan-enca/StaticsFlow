# StaticsFlow environment variables — copy to .env.local and fill in values

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Auth (NextAuth / Auth.js v5)
AUTH_SECRET="generate with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Cloudflare R2 Storage
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="staticsflow-creatives"
R2_PUBLIC_URL=""

# AI APIs (BYOK — users provide their own in production)
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
