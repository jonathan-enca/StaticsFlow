// StaticsFlow — Prisma schema
// DB: Supabase PostgreSQL
// Auth: Auth.js v5 (NextAuth) with Prisma adapter

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URLs are configured in prisma.config.ts (Prisma v7)
}

// ──────────────────────────────────────────────────────────────
// Auth.js required tables (do NOT rename fields)
// ──────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────────────────────────────────────────
// StaticsFlow domain models
// ──────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  emailVerified    DateTime?
  name             String?
  image            String?
  password         String?   // hashed with bcrypt (null for OAuth users)
  stripeCustomerId String?   @unique
  plan             Plan      @default(STARTER)
  isAdmin          Boolean   @default(false) // admin-only: access to BDD Manager
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // BYOK — per-user API keys (encrypted at rest in production)
  anthropicApiKey  String?
  geminiApiKey     String?

  accounts   Account[]
  sessions   Session[]
  brands     Brand[]
  favorites  UserFavorite[]
}

model Brand {
  id           String   @id @default(cuid())
  userId       String
  name         String
  url          String
  // Global Brand DNA stored as JSON blob (colors, fonts, tone, personas, etc.)
  // competitorBrands removed — had zero impact on generation outputs
  brandDnaJson Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  creatives    Creative[]
  batches      Batch[]
  products     Product[]
  inspirations Inspiration[]

  @@unique([userId, url])
}

// Per-brand product entity — v2 — rich Product DNA model
// Each product is a first-class entity with URL extraction + full asset library
model Product {
  id              String   @id @default(cuid())
  brandId         String
  name            String
  description     String?  @db.Text

  // === Product DNA v2 fields ===
  sourceUrl             String?   // URL used for auto-extraction (mandatory if extracted)
  tagline               String?   // Short product promise
  price                 String?   // e.g. "€49.90"
  currency              String?   // EUR, USD, GBP, etc.

  // Structured data arrays
  benefits              String[]  @default([]) // Product-specific benefits
  claims                String[]  @default([]) // "Dermatologist tested", "SPF50", etc.
  ingredients           String[]  @default([]) // Key ingredients/components
  specsJson             Json?                  // Key-value specs {"Volume": "50ml"}

  // Image asset libraries (R2 URLs)
  productImages         String[]  @default([]) // Packshots — min 3 for generation
  lifestyleImages       String[]  @default([]) // In-context shots
  packagingImages       String[]  @default([]) // Packaging-focused shots
  ugcImages             String[]  @default([]) // User-generated content images
  icons                 String[]  @default([]) // Product-specific badges/icons

  // Product-specific copy intelligence
  reviewsVerbatim       String[]  @default([]) // Real customer quotes (max 10)
  reviewsSummary        String?   @db.Text      // AI-synthesized sentiment
  productSpecificCTAs   String[]  @default([]) // Overrides Brand DNA CTAs
  productSpecificHooks  String[]  @default([]) // Overrides Brand DNA hooks
  avoidForThisProduct   String[]  @default([]) // Product-specific don'ts

  // Legacy fields (kept for backward compat, not written to by new code)
  iconsAndUiElements    String[]  @default([])
  moodboardAssets       String[]  @default([])

  // Status + defaults
  isActive              Boolean   @default(true)
  isDefault             Boolean   @default(false) // One per brand — auto-selected in wizard
  extractionStatus      String    @default("pending") // pending | extracting | done | failed
  extractedAt           DateTime?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  brand     Brand      @relation(fields: [brandId], references: [id], onDelete: Cascade)
  creatives Creative[]

  @@index([brandId])
}

model Creative {
  id        String         @id @default(cuid())
  brandId   String
  batchId   String?        // Set when generated as part of a batch
  imageUrl  String?        // R2 URL of the generated image
  briefJson Json           @default("{}") // Claude brief that produced this creative
  status    CreativeStatus @default(GENERATING)
  score     Float?         // QA score (0–1)
  format    String         @default("1080x1080") // AdFormat
  angle     String         @default("benefit")   // CreativeAngle

  // Generation provenance (Phase A/B/C)
  productId      String? // FK → Product (nullable for backward compat)
  inspirationId  String? // FK → Inspiration (nullable for backward compat)
  generationMode String? // "auto" | "manual" | "reference" | null (legacy)

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  brand       Brand        @relation(fields: [brandId], references: [id], onDelete: Cascade)
  batch       Batch?       @relation(fields: [batchId], references: [id], onDelete: SetNull)
  product     Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)
  inspiration Inspiration? @relation(fields: [inspirationId], references: [id], onDelete: SetNull)
}

// Per-brand visual inspirations library — uploaded ad screenshots analyzed by Claude
// Used as structural references for creative cloning (Phase B)
model Inspiration {
  id           String    @id @default(cuid())
  brandId      String
  imageUrl     String    // R2 URL of the original uploaded image
  thumbnailUrl String?   // R2 URL of resized thumbnail
  imageHash    String?   // SHA-256 hash for deduplication
  analysisJson Json      @default("{}") // InspirationAnalysis schema (see spec Section 3.2)
  isActive     Boolean   @default(true)
  uploadedAt   DateTime  @default(now())
  analyzedAt   DateTime? // null until Claude analysis completes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brand     Brand      @relation(fields: [brandId], references: [id], onDelete: Cascade)
  creatives Creative[]

  @@index([brandId])
}

// Batch generation job — tracks progress of a multi-creative generation request
model Batch {
  id             String      @id @default(cuid())
  brandId        String
  userId         String
  totalCount     Int
  completedCount Int         @default(0)
  status         BatchStatus @default(PENDING)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  brand     Brand      @relation(fields: [brandId], references: [id], onDelete: Cascade)
  creatives Creative[]
}

// Inspiration templates in the living BDD (base de données) of ad creatives
// Fed by admin batch upload + Claude auto-analysis
model Template {
  id             String    @id @default(cuid())
  category       String    // skincare | food | fashion | tech | fitness | home | beauty | health | pet | other
  type           String    // product_hero | before_after | comparatif | testimonial | promo | ugc_screenshot | lifestyle | data_stats | listicle | press_mention
  layout         String    @default("other") // grid | split | centered | overlay | other
  hookType       String    @default("benefice_direct") // pain | curiosite | social_proof | fomo | benefice_direct | autorite | urgence
  palette        String[]  // dominant hex colors (top 3)
  language       String    @default("fr") // fr | en | de | other
  sourceImageUrl String    // R2 URL of the original uploaded creative
  thumbnailUrl   String?   // R2 URL of resized thumbnail (generated post-upload)
  analysisJson   Json      @default("{}") // full Claude analysis output
  uploadedAt     DateTime  @default(now())
  analyzedAt     DateTime? // null until Claude analysis completes
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  favorites UserFavorite[]

  @@index([category, type])
  @@index([hookType])
  @@index([language])
}

// User favorites in the Inspiration Library
model UserFavorite {
  id         String   @id @default(cuid())
  userId     String
  templateId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([userId, templateId])
  @@index([userId])
}

// ──────────────────────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────────────────────

enum Plan {
  STARTER // 29€/mo — 1 brand
  PRO     // 79€/mo — 3 brands
  AGENCY  // 199€/mo — unlimited brands
}

enum CreativeStatus {
  GENERATING
  QA_REVIEW
  APPROVED
  REJECTED
}

enum BatchStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}
