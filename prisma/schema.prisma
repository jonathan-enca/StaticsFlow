// StaticsFlow — Prisma schema
// DB: Supabase PostgreSQL
// Auth: Auth.js v5 (NextAuth) with Prisma adapter

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URLs are now configured in prisma.config.ts (Prisma v7)
}

// ──────────────────────────────────────────────────────────────
// Auth.js required tables (do NOT rename fields)
// ──────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────────────────────────────────────────
// StaticsFlow domain models
// ──────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  emailVerified    DateTime?
  name             String?
  image            String?
  password         String?   // hashed with bcrypt (null for OAuth users)
  stripeCustomerId String?   @unique
  plan             Plan      @default(STARTER)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // BYOK — per-user API keys (encrypted at rest in production)
  anthropicApiKey  String?
  geminiApiKey     String?

  accounts  Account[]
  sessions  Session[]
  brands    Brand[]
}

model Brand {
  id           String   @id @default(cuid())
  userId       String
  name         String
  url          String
  // Full Brand DNA stored as JSON blob for flexibility
  brandDnaJson Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  creatives Creative[]
}

model Creative {
  id        String         @id @default(cuid())
  brandId   String
  imageUrl  String?        // R2 URL of the generated image
  briefJson Json           @default("{}") // Claude brief that produced this creative
  status    CreativeStatus @default(GENERATING)
  score     Float?         // QA score (0–1)
  format    String         @default("1080x1080") // AdFormat
  angle     String         @default("benefit")   // CreativeAngle
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)
}

// Inspiration templates in the living creative database
model Template {
  id             String   @id @default(cuid())
  category       String   // product category: skincare, food, fashion, etc.
  type           String   // creative type: product_hero, testimonial, etc.
  hookType       String   // pain, curiosity, social_proof, fomo, benefit, authority, urgency
  palette        String[] // dominant colors (hex)
  language       String   @default("fr")
  sourceImageUrl String   // R2 URL of the inspiration image
  analysisJson   Json     @default("{}") // Claude analysis of this template
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([category, type])
  @@index([hookType])
}

// ──────────────────────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────────────────────

enum Plan {
  STARTER // 29€/mo — 1 brand
  PRO     // 79€/mo — 3 brands
  AGENCY  // 199€/mo — unlimited brands
}

enum CreativeStatus {
  GENERATING
  QA_REVIEW
  APPROVED
  REJECTED
}
